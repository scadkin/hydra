# ===========================================
# Hydra — API Keys
# ===========================================
# Copy this file to .env.local and fill in your keys.
# You only need keys for the providers you want to use.
# Hydra will skip any provider without a key.
# ===========================================

# Anthropic (Claude)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google AI Studio (Gemini)
# Get your key at: https://aistudio.google.com/
GOOGLE_AI_API_KEY=your-google-ai-key-here

# xAI (Grok)
# Get your key at: https://console.x.ai/
XAI_API_KEY=xai-your-key-here

# DeepSeek
# Get your key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# OpenRouter (access to Llama, Qwen, DeepSeek R1, and 25+ other free models)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here
